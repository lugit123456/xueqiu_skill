# 数据库基础配置
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=hub_user
POSTGRES_PASSWORD=hub_password
POSTGRES_DB=financial_hub
DB_CHARSET=utf8mb4

# 采集配置
XUEQIU_USER_DATA_DIR=./xueqiu_user_data
CRAWL_RUN_MINUTES=20
# 是否隐藏浏览器窗口 (True 为隐藏，False 为显示)
BROWSER_HEADLESS=True
# --- 调度随机性配置 (单位：分钟) ---
# 启动前的随机等待范围
START_DELAY_MIN=0
START_DELAY_MAX=2

# 任务执行的时长范围，建议不要超过30分钟
RUN_DURATION_MIN=11
RUN_DURATION_MAX=17

# --- 避风港/静默期配置 (格式 HH:mm) ---在以下区间内不执行爬取任务
QUIET_START=23:30
QUIET_END=08:00

# 飞书机器人 Webhook 地址
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxx